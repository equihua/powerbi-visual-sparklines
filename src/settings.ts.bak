"use strict";

import { formattingSettings } from "powerbi-visuals-utils-formattingmodel";

import FormattingSettingsCard = formattingSettings.Card;
import FormattingSettingsSlice = formattingSettings.Slice;
import FormattingSettingsModel = formattingSettings.Model;

/**
 * Data Point Formatting Card
 */
class DataPointCardSettings extends FormattingSettingsCard {
  defaultColor = new formattingSettings.ColorPicker({
    name: "defaultColor",
    displayName: "Default color",
    value: { value: "" },
  });

  showAllDataPoints = new formattingSettings.ToggleSwitch({
    name: "showAllDataPoints",
    displayName: "Show all",
    value: true,
  });

  fill = new formattingSettings.ColorPicker({
    name: "fill",
    displayName: "Fill",
    value: { value: "" },
  });

  fillRule = new formattingSettings.ColorPicker({
    name: "fillRule",
    displayName: "Color saturation",
    value: { value: "" },
  });

  fontSize = new formattingSettings.NumUpDown({
    name: "fontSize",
    displayName: "Text Size",
    value: 12,
  });

  name: string = "dataPoint";
  displayName: string = "Data colors";
  slices: Array<FormattingSettingsSlice> = [
    this.defaultColor,
    this.showAllDataPoints,
    this.fill,
    this.fillRule,
    this.fontSize,
  ];
}

/**
 * Sparkline Line Settings Card
 */
class SparklineLineSettings extends FormattingSettingsCard {
  lineColor = new formattingSettings.ColorPicker({
    name: "lineColor",
    displayName: "Color de línea",
    value: { value: "#0078D4" },
  });

  lineWidth = new formattingSettings.NumUpDown({
    name: "lineWidth",
    displayName: "Grosor de línea",
    value: 2,
    options: {
      minValue: {
        type: formattingSettings.ValidatorType.Min,
        value: 0.5,
      },
      maxValue: {
        type: formattingSettings.ValidatorType.Max,
        value: 10,
      },
    },
  });

  lineOpacity = new formattingSettings.NumUpDown({
    name: "lineOpacity",
    displayName: "Opacidad de línea (%)",
    value: 100,
    options: {
      minValue: {
        type: formattingSettings.ValidatorType.Min,
        value: 0,
      },
      maxValue: {
        type: formattingSettings.ValidatorType.Max,
        value: 100,
      },
    },
  });

  curveType = new formattingSettings.ItemDropdown({
    name: "curveType",
    displayName: "Tipo de curva",
    items: [
      { displayName: "Linear", value: "linear" },
      { displayName: "Suave (Monotone)", value: "monotone" },
      { displayName: "Basis", value: "basis" },
      { displayName: "Cardinal", value: "cardinal" },
      { displayName: "Step", value: "step" },
      { displayName: "Step Before", value: "stepBefore" },
      { displayName: "Step After", value: "stepAfter" },
    ],
    value: { displayName: "Suave (Monotone)", value: "monotone" },
  });

  showArea = new formattingSettings.ToggleSwitch({
    name: "showArea",
    displayName: "Mostrar área bajo la línea",
    value: false,
  });

  areaColor = new formattingSettings.ColorPicker({
    name: "areaColor",
    displayName: "Color de área",
    value: { value: "#0078D4" },
  });

  areaOpacity = new formattingSettings.NumUpDown({
    name: "areaOpacity",
    displayName: "Opacidad de área (%)",
    value: 20,
    options: {
      minValue: {
        type: formattingSettings.ValidatorType.Min,
        value: 0,
      },
      maxValue: {
        type: formattingSettings.ValidatorType.Max,
        value: 100,
      },
    },
  });

  name: string = "sparklineLineSettings";
  displayName: string = "Línea del Sparkline";
  slices: Array<FormattingSettingsSlice> = [
    this.lineColor,
    this.lineWidth,
    this.lineOpacity,
    this.curveType,
    this.showArea,
    this.areaColor,
    this.areaOpacity,
  ];
}

/**
 * Sparkline Points Settings Card
 */
class SparklinePointsSettings extends FormattingSettingsCard {
  showPoints = new formattingSettings.ToggleSwitch({
    name: "showPoints",
    displayName: "Mostrar puntos",
    value: false,
  });

  pointRadius = new formattingSettings.NumUpDown({
    name: "pointRadius",
    displayName: "Radio de puntos",
    value: 3,
    options: {
      minValue: {
        type: formattingSettings.ValidatorType.Min,
        value: 1,
      },
      maxValue: {
        type: formattingSettings.ValidatorType.Max,
        value: 10,
      },
    },
  });

  pointColor = new formattingSettings.ColorPicker({
    name: "pointColor",
    displayName: "Color de puntos",
    value: { value: "#0078D4" },
  });

  pointBorderWidth = new formattingSettings.NumUpDown({
    name: "pointBorderWidth",
    displayName: "Grosor de borde",
    value: 0,
    options: {
      minValue: {
        type: formattingSettings.ValidatorType.Min,
        value: 0,
      },
      maxValue: {
        type: formattingSettings.ValidatorType.Max,
        value: 5,
      },
    },
  });

  pointBorderColor = new formattingSettings.ColorPicker({
    name: "pointBorderColor",
    displayName: "Color de borde",
    value: { value: "#FFFFFF" },
  });

  highlightFirstLast = new formattingSettings.ToggleSwitch({
    name: "highlightFirstLast",
    displayName: "Destacar primer/último punto",
    value: false,
  });

  firstPointColor = new formattingSettings.ColorPicker({
    name: "firstPointColor",
    displayName: "Color primer punto",
    value: { value: "#28A745" },
  });

  lastPointColor = new formattingSettings.ColorPicker({
    name: "lastPointColor",
    displayName: "Color último punto",
    value: { value: "#DC3545" },
  });

  name: string = "sparklinePointsSettings";
  displayName: string = "Puntos del Sparkline";
  slices: Array<FormattingSettingsSlice> = [
    this.showPoints,
    this.pointRadius,
    this.pointColor,
    this.pointBorderWidth,
    this.pointBorderColor,
    this.highlightFirstLast,
    this.firstPointColor,
    this.lastPointColor,
  ];
}

/**
 * Sparkline Layout Settings Card
 */
class SparklineLayoutSettings extends FormattingSettingsCard {
  sparklineHeight = new formattingSettings.NumUpDown({
    name: "sparklineHeight",
    displayName: "Altura de sparkline",
    value: 40,
    options: {
      minValue: {
        type: formattingSettings.ValidatorType.Min,
        value: 20,
      },
      maxValue: {
        type: formattingSettings.ValidatorType.Max,
        value: 200,
      },
    },
  });

  sparklineWidth = new formattingSettings.NumUpDown({
    name: "sparklineWidth",
    displayName: "Ancho de sparkline",
    value: 200,
    options: {
      minValue: {
        type: formattingSettings.ValidatorType.Min,
        value: 50,
      },
      maxValue: {
        type: formattingSettings.ValidatorType.Max,
        value: 800,
      },
    },
  });

  rowSpacing = new formattingSettings.NumUpDown({
    name: "rowSpacing",
    displayName: "Espaciado entre filas",
    value: 8,
    options: {
      minValue: {
        type: formattingSettings.ValidatorType.Min,
        value: 0,
      },
      maxValue: {
        type: formattingSettings.ValidatorType.Max,
        value: 50,
      },
    },
  });

  backgroundColor = new formattingSettings.ColorPicker({
    name: "backgroundColor",
    displayName: "Color de fondo",
    value: { value: "#F9F9F9" },
  });

  chartBackgroundColor = new formattingSettings.ColorPicker({
    name: "chartBackgroundColor",
    displayName: "Color de fondo del gráfico",
    value: { value: "#FFFFFF" },
  });

  showBorder = new formattingSettings.ToggleSwitch({
    name: "showBorder",
    displayName: "Mostrar bordes",
    value: true,
  });

  borderColor = new formattingSettings.ColorPicker({
    name: "borderColor",
    displayName: "Color de borde",
    value: { value: "#E0E0E0" },
  });

  borderRadius = new formattingSettings.NumUpDown({
    name: "borderRadius",
    displayName: "Radio de borde",
    value: 4,
    options: {
      minValue: {
        type: formattingSettings.ValidatorType.Min,
        value: 0,
      },
      maxValue: {
        type: formattingSettings.ValidatorType.Max,
        value: 20,
      },
    },
  });

  name: string = "sparklineLayoutSettings";
  displayName: string = "Diseño y Layout";
  slices: Array<FormattingSettingsSlice> = [
    this.sparklineHeight,
    this.sparklineWidth,
    this.rowSpacing,
    this.backgroundColor,
    this.chartBackgroundColor,
    this.showBorder,
    this.borderColor,
    this.borderRadius,
  ];
}

/**
 * Sparkline Labels Settings Card
 */
class SparklineLabelSettings extends FormattingSettingsCard {
  labelWidth = new formattingSettings.NumUpDown({
    name: "labelWidth",
    displayName: "Ancho de etiqueta",
    value: 150,
    options: {
      minValue: {
        type: formattingSettings.ValidatorType.Min,
        value: 50,
      },
      maxValue: {
        type: formattingSettings.ValidatorType.Max,
        value: 400,
      },
    },
  });

  fontSize = new formattingSettings.NumUpDown({
    name: "fontSize",
    displayName: "Tamaño de fuente",
    value: 12,
    options: {
      minValue: {
        type: formattingSettings.ValidatorType.Min,
        value: 8,
      },
      maxValue: {
        type: formattingSettings.ValidatorType.Max,
        value: 24,
      },
    },
  });

  fontColor = new formattingSettings.ColorPicker({
    name: "fontColor",
    displayName: "Color de texto",
    value: { value: "#000000" },
  });

  fontBold = new formattingSettings.ToggleSwitch({
    name: "fontBold",
    displayName: "Texto en negrita",
    value: true,
  });

  showValues = new formattingSettings.ToggleSwitch({
    name: "showValues",
    displayName: "Mostrar valores",
    value: false,
  });

  valuePosition = new formattingSettings.ItemDropdown({
    name: "valuePosition",
    displayName: "Posición de valores",
    items: [
      { displayName: "Ninguno", value: "none" },
      { displayName: "Inicio", value: "start" },
      { displayName: "Final", value: "end" },
      { displayName: "Ambos", value: "both" },
    ],
    value: { displayName: "Ninguno", value: "none" },
  });

  valueFormat = new formattingSettings.ItemDropdown({
    name: "valueFormat",
    displayName: "Formato de valores",
    items: [
      { displayName: "Automático", value: "auto" },
      { displayName: "Número", value: "number" },
      { displayName: "Moneda", value: "currency" },
      { displayName: "Porcentaje", value: "percentage" },
      { displayName: "Compacto", value: "compact" },
    ],
    value: { displayName: "Automático", value: "auto" },
  });

  name: string = "sparklineLabelSettings";
  displayName: string = "Etiquetas y Texto";
  slices: Array<FormattingSettingsSlice> = [
    this.labelWidth,
    this.fontSize,
    this.fontColor,
    this.fontBold,
    this.showValues,
    this.valuePosition,
    this.valueFormat,
  ];
}

/**
 * Sparkline Highlight Settings Card
 */
class SparklineHighlightSettings extends FormattingSettingsCard {
  showMinMax = new formattingSettings.ToggleSwitch({
    name: "showMinMax",
    displayName: "Mostrar valores mín/máx",
    value: false,
  });

  maxPointColor = new formattingSettings.ColorPicker({
    name: "maxPointColor",
    displayName: "Color punto máximo",
    value: { value: "#28A745" },
  });

  minPointColor = new formattingSettings.ColorPicker({
    name: "minPointColor",
    displayName: "Color punto mínimo",
    value: { value: "#DC3545" },
  });

  maxPointRadius = new formattingSettings.NumUpDown({
    name: "maxPointRadius",
    displayName: "Radio punto máximo",
    value: 4,
    options: {
      minValue: {
        type: formattingSettings.ValidatorType.Min,
        value: 2,
      },
      maxValue: {
        type: formattingSettings.ValidatorType.Max,
        value: 12,
      },
    },
  });

  minPointRadius = new formattingSettings.NumUpDown({
    name: "minPointRadius",
    displayName: "Radio punto mínimo",
    value: 4,
    options: {
      minValue: {
        type: formattingSettings.ValidatorType.Min,
        value: 2,
      },
      maxValue: {
        type: formattingSettings.ValidatorType.Max,
        value: 12,
      },
    },
  });

  showReferenceLine = new formattingSettings.ToggleSwitch({
    name: "showReferenceLine",
    displayName: "Mostrar línea de referencia",
    value: false,
  });

  referenceLineValue = new formattingSettings.NumUpDown({
    name: "referenceLineValue",
    displayName: "Valor de referencia",
    value: 0,
  });

  referenceLineColor = new formattingSettings.ColorPicker({
    name: "referenceLineColor",
    displayName: "Color línea de referencia",
    value: { value: "#FFC107" },
  });

  referenceLineStyle = new formattingSettings.ItemDropdown({
    name: "referenceLineStyle",
    displayName: "Estilo de línea",
    items: [
      { displayName: "Sólida", value: "solid" },
      { displayName: "Punteada", value: "dashed" },
      { displayName: "Punteada (puntos)", value: "dotted" },
    ],
    value: { displayName: "Punteada", value: "dashed" },
  });

  name: string = "sparklineHighlightSettings";
  displayName: string = "Valores Destacados";
  slices: Array<FormattingSettingsSlice> = [
    this.showMinMax,
    this.maxPointColor,
    this.minPointColor,
    this.maxPointRadius,
    this.minPointRadius,
    this.showReferenceLine,
    this.referenceLineValue,
    this.referenceLineColor,
    this.referenceLineStyle,
  ];
}

/**
 * Sparkline Interaction Settings Card
 */
class SparklineInteractionSettings extends FormattingSettingsCard {
  enableHover = new formattingSettings.ToggleSwitch({
    name: "enableHover",
    displayName: "Habilitar hover",
    value: true,
  });

  hoverColor = new formattingSettings.ColorPicker({
    name: "hoverColor",
    displayName: "Color de hover",
    value: { value: "#F0F0F0" },
  });

  enableSelection = new formattingSettings.ToggleSwitch({
    name: "enableSelection",
    displayName: "Habilitar selección",
    value: true,
  });

  selectionColor = new formattingSettings.ColorPicker({
    name: "selectionColor",
    displayName: "Color de selección",
    value: { value: "#E8F4F8" },
  });

  selectionBorderColor = new formattingSettings.ColorPicker({
    name: "selectionBorderColor",
    displayName: "Color borde de selección",
    value: { value: "#0078D4" },
  });

  selectionBorderWidth = new formattingSettings.NumUpDown({
    name: "selectionBorderWidth",
    displayName: "Grosor borde de selección",
    value: 2,
    options: {
      minValue: {
        type: formattingSettings.ValidatorType.Min,
        value: 0,
      },
      maxValue: {
        type: formattingSettings.ValidatorType.Max,
        value: 5,
      },
    },
  });

  showTooltips = new formattingSettings.ToggleSwitch({
    name: "showTooltips",
    displayName: "Mostrar tooltips",
    value: true,
  });

  animationDuration = new formattingSettings.NumUpDown({
    name: "animationDuration",
    displayName: "Duración animación (ms)",
    value: 200,
    options: {
      minValue: {
        type: formattingSettings.ValidatorType.Min,
        value: 0,
      },
      maxValue: {
        type: formattingSettings.ValidatorType.Max,
        value: 2000,
      },
    },
  });

  name: string = "sparklineInteractionSettings";
  displayName: string = "Interactividad";
  slices: Array<FormattingSettingsSlice> = [
    this.enableHover,
    this.hoverColor,
    this.enableSelection,
    this.selectionColor,
    this.selectionBorderColor,
    this.selectionBorderWidth,
    this.showTooltips,
    this.animationDuration,
  ];
}

/**
 * visual settings model class
 *
 */
export class VisualFormattingSettingsModel extends FormattingSettingsModel {
  // Create formatting settings model formatting cards
  dataPointCard = new DataPointCardSettings();
  sparklineLineCard = new SparklineLineSettings();
  sparklinePointsCard = new SparklinePointsSettings();
  sparklineLayoutCard = new SparklineLayoutSettings();
  sparklineLabelCard = new SparklineLabelSettings();
  sparklineHighlightCard = new SparklineHighlightSettings();
  sparklineInteractionCard = new SparklineInteractionSettings();

  cards = [
    this.sparklineLineCard,
    this.sparklinePointsCard,
    this.sparklineLayoutCard,
    this.sparklineLabelCard,
    this.sparklineHighlightCard,
    this.sparklineInteractionCard,
    this.dataPointCard,
  ];
}

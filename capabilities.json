{
  "dataRoles": [
    {
      "displayName": "Renglones",
      "name": "rows",
      "kind": "Grouping"
    },
    {
      "displayName": "Columnas",
      "name": "columns",
      "kind": "GroupingOrMeasure"
    },
    {
      "displayName": "Valores",
      "name": "values",
      "kind": "Measure"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "rows": {
            "max": 1000
          },
          "values": {
            "max": 50
          }
        }
      ],
      "matrix": {
        "rows": {
          "for": {
            "in": "rows"
          },
          "dataReductionAlgorithm": {
            "top": {
              "count": 1000
            }
          }
        },
        "columns": {
          "for": {
            "in": "columns"
          },
          "dataReductionAlgorithm": {
            "top": {
              "count": 100
            }
          }
        },
        "values": {
          "select": [
            {
              "for": {
                "in": "values"
              }
            }
          ]
        }
      }
    }
  ],
  "objects": {
    "sparklineSettings": {
      "displayName": "Formato de minigráficos",
      "properties": {
        "lineColor": {
          "displayName": "Color de línea",
          "type": {
            "fill": {
              "solid": {
                "color": true
              }
            }
          }
        },
        "lineWidth": {
          "displayName": "Grosor de línea",
          "type": {
            "numeric": true
          }
        },
        "showPoints": {
          "displayName": "Mostrar puntos",
          "type": {
            "bool": true
          }
        }
      }
    }
  },
  "sorting": {
    "default": {}
  },
  "privileges": []
}
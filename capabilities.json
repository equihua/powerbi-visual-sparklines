{
  "dataRoles": [
    {
      "displayName": "Renglones",
      "name": "rows",
      "kind": "Grouping"
    },
    {
      "displayName": "Columnas",
      "name": "columns",
      "kind": "GroupingOrMeasure"
    },
    {
      "displayName": "Valores",
      "name": "values",
      "kind": "Measure"
    },
    {
      "displayName": "Categoría de minigráfico",
      "name": "sparklineCategory",
      "kind": "Grouping"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "rows": {
            "max": 1000
          },
          "values": {
            "max": 50
          }
        }
      ],
      "matrix": {
        "rows": {
          "for": {
            "in": "rows"
          },
          "dataReductionAlgorithm": {
            "top": {
              "count": 1000
            }
          }
        },
        "columns": {
          "for": {
            "in": "columns"
          },
          "dataReductionAlgorithm": {
            "top": {
              "count": 100
            }
          }
        },
        "values": {
          "select": [
            {
              "for": {
                "in": "values"
              }
            }
          ]
        }
      }
    }
  ],
